# Local development placeholders only.
# Do not add real secrets, production URLs, tokens, private keys, or Apple credentials.

APP_ENVIRONMENT=local
APP_NAME=ai-app-starter-swiftui-fastapi
APP_VERSION=0.1.0-dev

# P3-A uses local-only SQLite. P4 will add PostgreSQL through Docker Compose.
DATABASE_URL=sqlite:///./.local/ai_app_starter.db

# Placeholder only. Do not use this value in production.
JWT_SECRET_KEY=local-development-placeholder-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

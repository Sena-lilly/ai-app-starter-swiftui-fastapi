# Local development placeholders only.
# Do not add real secrets, production URLs, tokens, private keys, or Apple credentials.

APP_ENVIRONMENT=local
APP_NAME=ai-app-starter-swiftui-fastapi
APP_VERSION=0.1.0-dev

# Default fast local development uses SQLite.
DATABASE_URL=sqlite:///./.local/ai_app_starter.db

# Optional host-to-Docker PostgreSQL URL for running backend outside Docker.
# Keep this commented unless you are using local Docker PostgreSQL.
# DATABASE_URL=postgresql+psycopg://app_user:app_password@localhost:5432/ai_app_starter

# Local-only Docker Compose PostgreSQL placeholders.
# Do not reuse these values in production.
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_DB=ai_app_starter

# Placeholder only. Do not use this value in production.
JWT_SECRET_KEY=local-development-placeholder-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
